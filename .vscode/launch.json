{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug test-pdf (Excel)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/test/pdf",
            "args": [
                "-format", "xlsx",
                "-name", "TestReportExcel",
                "-output-folder", "test-reports",
                "-certs-path", "test/certs/sa-win2k25"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "mkdir-test-reports"
        },
        {
            "name": "Debug test-pdf (PDF)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/test/pdf",
            "args": [
                "-format", "pdf",
                "-name", "TestReportPDF",
                "-output-folder", "test-reports",
                "-orientation", "portrait",
                "-certs-path", "test/certs/sa-win2k25"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "mkdir-test-reports"
        },
        {
            "name": "Debug test-pdf (Custom Excel)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/test/pdf",
            "args": [
                "-format", "xlsx",
                "-name", "TestReportCustomExcel",
                "-obj-ids", "RfEbJ",
                "-output-folder", "test-reports",
                "-certs-path", "test/certs/sa-win2k25"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "mkdir-test-reports"
        },
        {
            "name": "Debug test-pdf (Custom PDF)",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/test/pdf",
            "args": [
                "-format", "pdf",
                "-name", "TestReportCustomPDF",
                "-output-folder", "test-reports",
                "-orientation", "portrait",
                "-obj-ids", "RfEbJ",
                "-certs-path", "test/certs/sa-win2k25"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "mkdir-test-reports"
        },
        {
            "name": "Debug test-excel-paging",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/test/excel_paging",
            "args": [
                "-rows-per-page", "100",
                "-title", "TestPaginatedReport",
                "-show-col-nums",
                "-show-subtotals",
                "-all-borders",
                "-output-selection",
                "-name", "TestPaginatedReport",
                "-output-folder", "test-reports",
                "-certs-path", "test/certs/sa-win2k25"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "mkdir-test-reports"
        }
    ]
}